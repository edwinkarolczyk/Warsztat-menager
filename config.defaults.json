{
  "config_version": 1,
  "ui": {
    "theme": "dark",
    "accent": "red",
    "always_searchbar": true,
    "language": "pl",
    "colors": {
      "dark_bg": "#1b1f24",
      "dark_bg_2": "#20262e",
      "side_bg": "#14181d",
      "card_bg": "#20262e",
      "fg": "#e6e6e6",
      "muted_fg": "#9aa0a6",
      "btn_bg": "#2a3139",
      "btn_bg_hover": "#343b45",
      "btn_bg_act": "#3b434e",
      "banner_fg": "#ff4d4d",
      "banner_bg": "#1b1b1b"
    },
    "start_on_dashboard": true,
    "auto_check_updates": true,
    "debug_enabled": true,
    "log_level": "debug"
  },
  "app": {
    "start_view": "dashboard"
  },
  "auth": {
    "required": true,
    "session_timeout_min": 30,
    "pin_length": 4,
    "pinless_brygadzista": false,
    "auto_login_enabled": false,
    "auto_login_profile": ""
  },
  "paths": {
    "data_root": "data",
    "logs_dir": "logs",
    "backup_dir": "backup",
    "layout_dir": "data/layout"
  },
  "sciezka_danych": "{ROOT}/data",
  "backup": {
    "folder": "backup",
    "keep_last": 10,
    "cloud": {
      "url": "",
      "username": "",
      "password": "",
      "folder": ""
    }
  },
  "updates": {
    "auto": true,
    "remote": "origin",
    "branch": "Rozwiniecie",
    "push_branch": "Rozwiniecie",
    "auto_pull": true
  },
  "jarvis": {
    "enabled": true,
    "allow_ai": true,
    "model": "gpt-3.5-turbo",
    "auto_interval_sec": 900,
    "notify": {
      "refresh_ms": 10000
    },
    "role_access": [
      "brygadzista",
      "admin"
    ]
  },
  "feedback": {
    "url": ""
  },
  "modules": {
    "service": {
      "enabled": true
    }
  },
  "dashboard": {
    "mini_hall": {
      "enabled": true
    }
  },
  "hall": {
    "grid_size_px": 4,
    "drag_snap_px": 20,
    "triple_confirm_delete": false
  },
  "local": {
    "fullscreen_on_start": false,
    "ui_scale": 100
  },
  "profiles": {
    "tab_enabled": true,
    "show_name_in_header": true,
    "avatar": {
      "enabled": false,
      "directory": ""
    },
    "fields_visible": [
      "login",
      "nazwa",
      "rola",
      "zmiana"
    ],
    "editable_fields": [
      "imie",
      "nazwisko",
      "staz",
      "telefon",
      "email"
    ],
    "pin": {
      "change_allowed": false,
      "min_length": 4
    },
    "task_default_deadline_days": 7
  },
  "shifts": {
    "anchor_monday": "2025-01-06",
    "patterns": {
      "111": "111",
      "112": "112",
      "12": "12",
      "121": "121",
      "211": "211",
      "1212": "1212"
    },
    "modes": {}
  },
  "magazyn": {
    "require_reauth": true,
    "rounding": {
      "mb_precision": 3,
      "enforce_integer_for_szt": true
    }
  },
  "magazyn_rezerwacje": true,
  "produkty_dir": "data/produkty/",
  "produkty_auto_sync": false,
  "polprodukty_dir": "data/polprodukty/",
  "polprodukty_auto_sync": false,
  "surowce_file": "data/magazyn/surowce.json",
  "progi_alertow_surowce": {},
  "progi_alertow_pct": [
    100
  ],
  "czynnosci_technologiczne": [],
  "jednostki_miary": {
    "szt": "sztuka",
    "kg": "kilogram",
    "m": "metr"
  },
  "warn_on_unsaved": true,
  "autosave_draft": false,
  "autosave_draft_interval_sec": 15,
  "tutorial_completed": false,
  "secrets": {
    "admin_pin": ""
  },
  "tools": {
    "collections_enabled": [
      "NN",
      "SN"
    ],
    "default_collection": "NN",
    "preview_delay_sec": 3,
    "sn_range": [
      500,
      1000
    ],
    "validate_sn_range": false,
    "auto_check_on_status_global": [
      "sprawne",
      "zakończone"
    ],
    "collections_paths": {},
    "types": [
      "Tłoczące",
      "Wykrawające",
      "Postępowe",
      "Giętarka"
    ],
    "statuses": [
      "awaria zgłoszona",
      "diagnoza",
      "w naprawie",
      "test",
      "sprawdzona",
      "zakończone",
      "anulowane"
    ],
    "task_templates": [
      "zadanie testowe",
      "zadanie testowe1",
      "zadanie testowe2",
      "zadanie testowe3",
      "zadanie testowe4",
      "zadanie testowe5",
      "zadanie testowe6",
      "zadanie testowe7",
      "zadanie testowe8",
      "zadanie testowe9"
    ]
  },
  "narzedzia": {
    "typy": [],
    "komentarze": {
      "wg_statusu": false
    }
  },
  "orders": {
    "id_width": 4,
    "types": {
      "ZW": {
        "enabled": true,
        "label": "Zlecenie wewnętrzne",
        "prefix": "ZW-",
        "reserve_by_default": false,
        "requires_approval": false,
        "wizard": false,
        "statuses": [
          "nowe",
          "w trakcie",
          "zakończone",
          "anulowane"
        ]
      },
      "ZN": {
        "enabled": true,
        "label": "Zlecenie na narzędzie",
        "prefix": "ZN-",
        "reserve_by_default": true,
        "requires_approval": false,
        "wizard": true,
        "statuses": [
          "projekt",
          "w budowie",
          "1 próba",
          "2 próba",
          "odbiór",
          "na produkcji",
          "anulowane"
        ]
      },
      "ZM": {
        "enabled": true,
        "label": "Naprawa/awaria maszyny",
        "prefix": "ZM-",
        "reserve_by_default": true,
        "requires_approval": false,
        "wizard": true,
        "statuses": [
          "awaria zgłoszona",
          "diagnoza",
          "w naprawie",
          "test",
          "sprawdzona",
          "zakończone",
          "anulowane"
        ]
      }
    }
  },
  "dyspo": {
    "enabled_types": [
      "DM",
      "DZ",
      "DW",
      "DN"
    ],
    "numbering": {
      "DM": {
        "pattern": "DM-{YYYY}-{####}",
        "counter": 1
      },
      "DZ": {
        "pattern": "DZ-{YYYY}-{####}",
        "counter": 1
      },
      "DW": {
        "pattern": "DW-{YYYY}-{####}",
        "counter": 1
      },
      "DN": {
        "pattern": "DN-{YYYY}-{####}",
        "counter": 1
      }
    },
    "flow": "simple",
    "required": {
      "machine_id": true,
      "tool_id": false,
      "at_least_one_item": true
    },
    "shortcuts": {
      "ctrlD": true
    }
  }
}
