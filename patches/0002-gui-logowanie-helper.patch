 gui_logowanie.py | 43 +++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 43 insertions(+)

diff --git a/gui_logowanie.py b/gui_logowanie.py
index 0000001..0000002 100644
--- a/gui_logowanie.py
+++ b/gui_logowanie.py
@@ -1,3 +1,10 @@
+"""
+UWAGA (Warsztat Menager):
+Ten patch tylko DODAJE helpera do obsługi listy użytkowników na ekranie
+logowania. Nie usuwa żadnego istniejącego kodu.
+Po zastosowaniu patcha trzeba jeszcze ręcznie podpiąć wywołanie
+_reload_user_list() w odpowiednim miejscu (np. w __init__ okna logowania).
+"""
+
+from core.users import get_login_users  # nowy import
+
 # ... tutaj istniejące importy i kod gui_logowanie ...
+
+
+class LoginWindow:  # DOPASUJ nazwę klasy, jeśli jest inna
+    # UWAGA: ten blok możesz wstawić do swojej istniejącej klasy
+    # okna logowania zamiast tworzyć nową, jeśli klasa nazywa się inaczej.
+
+    def _reload_user_list(self):
+        """Wczytuje użytkowników z core.users i uzupełnia combobox/loginy."""
+        users = get_login_users()
+        self._users_data = users
+
+        loginy = [u.get("login", "") for u in users if u.get("login")]
+
+        # TODO: dopasuj nazwę comboboxa / listy:
+        # np. self.combo_login, self.login_combobox, itp.
+        combo = getattr(self, "login_combobox", None)
+        if combo is not None:
+            combo["values"] = loginy
+            if loginy:
+                combo.set(loginy[0])
+
+# ⏹ KONIEC KODU
