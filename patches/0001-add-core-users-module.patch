+# core/users.py
+from typing import List, Dict, Any
+
+# TODO: dopasuj do swojego modułu ustawień:
+#  - użyj tego samego load_settings/save_settings,
+#    który ma moduł Ustawienia.
+from core.settings import load_settings, save_settings  # <-- dopasuj ścieżkę
+
+
+def get_login_users() -> List[Dict[str, Any]]:
+    """
+    Zwraca listę użytkowników widocznych na ekranie logowania.
+
+    Każdy użytkownik to słownik z kluczami co najmniej:
+      - login (str)
+      - name  (str, opcjonalnie)
+      - role  (str, opcjonalnie)
+      - enabled (bool, domyślnie True)
+      - system  (bool, opcjonalnie – np. dla 'admin')
+    """
+    settings = load_settings()
+
+    # TODO: dopasuj ścieżkę do tej używanej w Ustawieniach>>Użytkownicy
+    users = settings.get("users", [])
+
+    auth_cfg = settings.get("auth", {})
+    show_admin = auth_cfg.get("show_admin_on_login", True)
+
+    visible_users: List[Dict[str, Any]] = []
+
+    for user in users:
+        if not isinstance(user, dict):
+            continue
+
+        login = user.get("login")
+        if not login:
+            continue
+
+        # jeśli brak enabled – traktujemy jako True
+        if not user.get("enabled", True):
+            continue
+
+        # opcjonalne ukrywanie admina
+        if not show_admin and login == "admin":
+            continue
+
+        visible_users.append(user)
+
+    # fallback: jeśli nic nie ma, generujemy technicznego admina
+    if not visible_users:
+        visible_users = [{
+            "login": "admin",
+            "name": "Administrator",
+            "role": "admin",
+            "enabled": True,
+            "system": True,
+        }]
+
+    visible_users.sort(key=lambda u: (u.get("login") or "").lower())
+    return visible_users
+
+
+def get_user_by_login(login: str) -> Dict[str, Any] | None:
+    """Zwraca pełny słownik użytkownika po loginie albo None."""
+    for user in get_login_users():
+        if user.get("login") == login:
+            return user
+    return None
+
+
+def load_all_users(raw: bool = False) -> List[Dict[str, Any]]:
+    """
+    Zwraca pełną listę użytkowników z ustawień (bez filtrowania enabled).
+
+    raw=True  -> bez sortowania i filtrów,
+    raw=False -> posortowane po loginie.
+    """
+    settings = load_settings()
+    users = settings.get("users", [])
+
+    if raw:
+        return list(users)
+
+    clean: List[Dict[str, Any]] = [u for u in users if isinstance(u, dict)]
+    clean.sort(key=lambda u: (u.get("login") or "").lower())
+    return clean
+
+
+def save_all_users(users: List[Dict[str, Any]]) -> None:
+    """
+    Zapisuje pełną listę użytkowników do ustawień.
+
+    NIE dodaje admina – fallback 'admin' obsługuje get_login_users()
+    przy pustej liście.
+    """
+    settings = load_settings()
+    settings["users"] = list(users)
+    save_settings(settings)
+
+# ⏹ KONIEC KODU
