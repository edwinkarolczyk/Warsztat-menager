                  "default": "",
                  "options": []
                },
                {
                  "type": "number",
                  "key": "auth.session_timeout_min",
                  "label": "Timeout sesji (min)",
                  "tooltip": "Automatyczne wylogowanie po bezczynności.",
                  "default": 30,
                  "min": 5,
                  "max": 240
                }
              ]
            }
          ]
        }
      ]
    },
