  "$defs": {
    "numRule": {
      "type": "object",
      "properties": {
        "pattern": {
          "type": "string"
        },
        "counter": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "pattern",
        "counter"
      ],
      "additionalProperties": false
    }
  },
  "dyspo": {
    "type": "object",
    "title": "Dyspozycje",
    "properties": {
      "enabled_types": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "DM",
            "DZ",
            "DW",
            "DN"
          ]
        },
        "uniqueItems": true,
        "default": [
          "DM",
          "DZ",
          "DW",
          "DN"
        ]
      },
      "numbering": {
        "type": "object",
        "properties": {
          "DM": {
            "$ref": "#/$defs/numRule"
          },
          "DZ": {
            "$ref": "#/$defs/numRule"
          },
          "DW": {
            "$ref": "#/$defs/numRule"
          },
          "DN": {
            "$ref": "#/$defs/numRule"
          }
        },
        "additionalProperties": {
          "$ref": "#/$defs/numRule"
        }
      },
      "flow": {
        "type": "string",
        "enum": [
          "simple",
          "extended"
        ],
        "default": "simple"
      },
      "required": {
        "type": "object",
        "properties": {
          "machine_id": {
            "type": "boolean",
            "default": true
          },
          "tool_id": {
            "type": "boolean",
            "default": false
          },
          "at_least_one_item": {
            "type": "boolean",
            "default": true
          }
        },
        "additionalProperties": false
      },
      "shortcuts": {
        "type": "object",
        "properties": {
          "ctrlD": {
            "type": "boolean",
            "default": true
          }
        },
        "additionalProperties": false
      }
    },
    "required": [
      "enabled_types",
      "numbering",
      "flow",
      "required",
      "shortcuts"
    ],
    "additionalProperties": false
  }
}
